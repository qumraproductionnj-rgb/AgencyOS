# ─────────────────────────────────────────────────────────────────────────────
# AgencyOS — Production Environment Variables
# Copy to .env.prod and fill real values
# NEVER commit .env.prod to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
DATABASE_URL=postgresql://agencyos:${DB_PASSWORD}@postgres:5432/agencyos_prod
DIRECT_DATABASE_URL=postgresql://agencyos:${DB_PASSWORD}@postgres:5432/agencyos_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT Keys (generate: openssl genrsa -out private.pem 2048) ─────────────────
# Paste the full PEM content with literal \n or use base64 encoding
JWT_PRIVATE_KEY=PASTE_RSA_PRIVATE_KEY_HERE
JWT_PUBLIC_KEY=PASTE_RSA_PUBLIC_KEY_HERE

# ── Super Admin (first deploy only) ──────────────────────────────────────────
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── Anthropic (AI features) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXX

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_XXXX
EMAIL_FROM=noreply@agencyos.app

# ── Sentry (Error Tracking) ───────────────────────────────────────────────────
SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX
NEXT_PUBLIC_SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX

# ── Stripe (Billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# ── Cloudflare R2 (File Storage + Backups) ────────────────────────────────────
R2_ACCOUNT_ID=XXXX
R2_ACCESS_KEY_ID=XXXX
R2_SECRET_ACCESS_KEY=XXXX
R2_BUCKET=agencyos-prod
R2_PUBLIC_URL=https://files.agencyos.app
R2_ENDPOINT=https://XXXX.r2.cloudflarestorage.com

# ── Telegram (Notifications) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=XXXX:XXXX
TELEGRAM_CHAT_ID=-XXXX

# ── PostHog (Analytics) ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXX
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=https://app.agencyos.app
API_URL=https://api.agencyos.app
NEXT_PUBLIC_API_URL=https://api.agencyos.app

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
