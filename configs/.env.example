# =============================================================
# AgencyOS Environment Variables
# =============================================================
# Copy this file to .env (and .env.production for production)
# NEVER commit the actual .env files
# =============================================================

# -------------------------------------------------------------
# General
# -------------------------------------------------------------
NODE_ENV=development
APP_NAME=AgencyOS
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
PORTAL_URL=http://localhost:3003

# -------------------------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------------------------
DATABASE_URL=postgresql://agencyos:dev_password_change_me@localhost:5432/agencyos_dev?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=agencyos
DB_PASSWORD=dev_password_change_me
DB_NAME=agencyos_dev
DB_POOL_SIZE=10

# Direct connection for migrations (bypasses pooler)
DIRECT_DATABASE_URL=postgresql://agencyos:dev_password_change_me@localhost:5432/agencyos_dev?schema=public

# -------------------------------------------------------------
# Redis (Cache + Queue)
# -------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------------------------------------------
# JWT Keys
# -------------------------------------------------------------
# Generate via: openssl genrsa -out private.pem 2048
# Then: openssl rsa -in private.pem -pubout -out public.pem
# Use base64 encoded versions

# Tier 1 — Platform Admin
JWT_PLATFORM_PRIVATE_KEY=
JWT_PLATFORM_PUBLIC_KEY=

# Tier 2 — Tenant Users
JWT_TENANT_PRIVATE_KEY=
JWT_TENANT_PUBLIC_KEY=

# Tier 3 — External Users (Clients/Freelancers)
JWT_EXTERNAL_PRIVATE_KEY=
JWT_EXTERNAL_PUBLIC_KEY=

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -------------------------------------------------------------
# Encryption
# -------------------------------------------------------------
# 32 random bytes, base64 encoded
# Generate via: openssl rand -base64 32
ENCRYPTION_KEY=

# -------------------------------------------------------------
# Cloudflare R2 (Object Storage)
# -------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=agencyos-dev
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# -------------------------------------------------------------
# Anthropic API (AI Tools)
# -------------------------------------------------------------
# DIFFERENT key from the one Claude Code uses!
# This one is used INSIDE the application for AI tools
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-7

# -------------------------------------------------------------
# Email (Resend)
# -------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@agencyos.app
EMAIL_FROM_NAME=AgencyOS
EMAIL_REPLY_TO=support@agencyos.app

# -------------------------------------------------------------
# Telegram Bot
# -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=AgencyOSBot
TELEGRAM_WEBHOOK_SECRET=

# -------------------------------------------------------------
# Stripe (International Payments)
# -------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_AGENCY_MONTHLY=

# -------------------------------------------------------------
# Local Iraqi Payment Gateway (Phase 4)
# -------------------------------------------------------------
# To be filled when integration is implemented
FASTPAY_MERCHANT_ID=
FASTPAY_API_KEY=
FASTPAY_WEBHOOK_SECRET=

# -------------------------------------------------------------
# Sentry (Error Monitoring)
# -------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# -------------------------------------------------------------
# Plausible Analytics
# -------------------------------------------------------------
PLAUSIBLE_DOMAIN=agencyos.app

# -------------------------------------------------------------
# Geolocation (for GPS check-in IP-based fallback)
# -------------------------------------------------------------
# Optional - for fraud detection
IPGEOLOCATION_API_KEY=

# -------------------------------------------------------------
# Rate Limiting
# -------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------------------------
# Feature Flags
# -------------------------------------------------------------
FEATURE_AI_TOOLS_ENABLED=true
FEATURE_TELEGRAM_NOTIFICATIONS=true
FEATURE_LOCAL_PAYMENT=false  # Phase 4

# -------------------------------------------------------------
# Default Tenant Settings
# -------------------------------------------------------------
DEFAULT_TIMEZONE=Asia/Baghdad
DEFAULT_LANGUAGE=ar
DEFAULT_CURRENCY=IQD
DEFAULT_GRACE_PERIOD_MINUTES=15

# -------------------------------------------------------------
# File Upload Limits
# -------------------------------------------------------------
MAX_FILE_SIZE_MB=10240  # 10 GB
MAX_IMAGE_SIZE_MB=20
MAX_VIDEO_SIZE_MB=10240

# -------------------------------------------------------------
# Subscription Defaults
# -------------------------------------------------------------
TRIAL_DAYS=14
GRACE_PERIOD_DAYS_AFTER_EXPIRY=14
SUSPENSION_DAYS_AFTER_GRACE=90

# -------------------------------------------------------------
# Background Jobs
# -------------------------------------------------------------
JOB_QUEUE_CONCURRENCY=5
JOB_RETRY_ATTEMPTS=3

# -------------------------------------------------------------
# Logging
# -------------------------------------------------------------
LOG_LEVEL=debug  # debug | info | warn | error
LOG_FORMAT=pretty  # pretty | json (use json in production)

# -------------------------------------------------------------
# CORS
# -------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003

# -------------------------------------------------------------
# Development Tools
# -------------------------------------------------------------
PRISMA_STUDIO_PORT=5555
MAILHOG_UI_PORT=8025
