  projectId       String?       @map("project_id") @db.Uuid
  number          String        @unique
  type            InvoiceType   @default(STANDARD)
  status          InvoiceStatus @default(DRAFT)
  items           Json          @default("[]")
  subtotal        BigInt        @default(0)
  discountPercent Decimal?      @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  BigInt?       @map("discount_amount")
  taxPercent      Decimal?      @map("tax_percent") @db.Decimal(5, 2)
  taxAmount       BigInt?       @map("tax_amount")
  total           BigInt        @default(0)
  paidAmount      BigInt        @default(0) @map("paid_amount")
  balanceDue      BigInt        @map("balance_due")
  currency        String        @default("IQD")
  dueDate         DateTime      @map("due_date") @db.Date
