/// Links a User (tier: EXTERNAL) to a Client for portal access.
model ClientPortalUser {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user    User    @relation("PortalUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId, clientId], name: "idx_cpu_company_client")
  @@index([companyId, userId], name: "idx_cpu_company_user")
  @@map("client_portal_users")
}

/// File annotations for client review (video timestamps, image coords, PDF page+region).
model FileAnnotation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid

  annotationType String @map("annotation_type") // timestamp | region | page_region | text
  content        String // the comment text

  // Timestamp annotation (for video)
  timestampSeconds Int? @map("timestamp_seconds")

  // Region annotation (for images)
  regionX  Int? @map("region_x")
  regionY  Int? @map("region_y")
  regionW  Int? @map("region_w")
  regionH  Int? @map("region_h")

  // Page annotation (for PDF)
  pageNumber Int?   @map("page_number")
  pageRegion Json?  @map("page_region") // { x, y, w, h }

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id])
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId], name: "idx_file_annotations_company_id")
  @@index([fileId], name: "idx_file_annotations_file_id")
  @@index([fileId, userId], name: "idx_file_annotations_file_user")
  @@map("file_annotations")
}

model Contact {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
